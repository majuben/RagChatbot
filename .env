DATABASE_URL=postgresql://postgres:postgres@db:5432/ragbot
DEFAULT_API_URL=http://localhost:8000/api/chat
# Use your host machine's Ollama service from the Docker container.
# On Windows Docker, host.docker.internal resolves to the host machine.
OLLAMA_URL=http://host.docker.internal:11434/
CHUNK_SIZE=200
CHUNK_OVERLAP=40
TOP_K_RETRIEVAL=15
TOP_K_FINAL=5
SIMILARITY_THRESHOLD=0.85
OLLAMA_MODEL=qwen3:8b  
OLLAMA_EMBEDDING_MODEL=nomic-embed-text